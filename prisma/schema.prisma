// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  passwordHash      String?
  isVerified        Boolean   @default(false)
  image             String?
  facebookConnected   Boolean   @default(false)
  facebookId          String?   @unique
  facebookAccessToken String?
  facebookPage        FacebookPage?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FacebookPage {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageId      String   @unique
  name        String
  accessToken String
  picture     String?
  contacts    Contact[]
  flows       AutomationFlow[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contact {
  id                String   @id @default(cuid())
  pageId            String
  page              FacebookPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  psid              String   @unique
  firstName         String?
  lastName          String?
  profilePic        String?
  messages          Message[]
  createdAt         DateTime @default(now())
  lastInteractiveAt DateTime @default(now())
}

model AutomationFlow {
  id              String   @id @default(cuid())
  pageId          String
  page            FacebookPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  name            String
  triggerKeywords String
  targetPostId    String?  // Facebook post ID, null means "any post"
  replyText       String?  // Public comment reply text
  dmText          String?  // Private DM text
  flowData        String   // Stringified JSON containing nodes and edges
  isActive        Boolean  @default(false)
  metricsSent     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Message {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  text        String
  direction   String   // "INBOUND" or "OUTBOUND"
  isRead      Boolean  @default(false)
  timestamp   DateTime @default(now())
}
